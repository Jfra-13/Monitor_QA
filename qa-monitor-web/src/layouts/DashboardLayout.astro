---
// src/layouts/DashboardLayout.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

// Obligamos a que cualquier página que use este layout le pase un "title"
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | QA Monitor</title>
    {/* Transiciones fluidas tipo SPA */}
    <ClientRouter />
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans flex h-screen overflow-hidden">
    
    <aside class="w-64 bg-slate-900 text-white flex flex-col shadow-xl z-10">
      <div class="p-6 border-b border-slate-800">
        <h1 class="text-2xl font-bold tracking-tight">QA Monitor</h1>
        <p class="text-xs text-slate-400 mt-1">Panel de Control Interno</p>
      </div>
      
      <nav class="flex-1 p-4 space-y-2">
        <a href="/" data-astro-reload class="block px-4 py-3 rounded-lg bg-slate-800  font-medium transition-colors hover:bg-slate-700">
          Monitor de APIs
        </a>
      </nav>
      
      <div class="p-4 border-t border-slate-800 text-xs text-slate-500 text-center">
        Motor Java: Operativo
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto bg-slate-50 p-8">
      {/* El <slot/> es el hueco donde Astro meterá el código de tus otras páginas */}
      <slot /> 
    </main>

  </body>
</html>