# -------------------------------
# General .gitignore (frontend/backed/workspace)
# Contenido sugerido por el usuario
# -------------------------------

# Dependencias (Node)
/node_modules/

# Builds / caches
dist/
.astro/
.cache/

# Environment / secrets
.env
.env.local
.env..local
.env.*

# Logs
npm-debug.log
yarn-debug.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Coverage / test artifacts
coverage/
coverage-final.json
.nyc_output/
.sass-cache/

# Misc
*.log
public/.DS_Store
/.parcel-cache
/.turbo
/.vercel
/.netlify

# ===============================
# .gitignore para el backend (Spring Boot / Maven)
# Mantener artefactos, compilados y configuraciones de IDE fuera del repo

HELP.md

# Build
/target/

# Mantener el wrapper jar ignorado si existe (el resto de .mvn suele comitearse)
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### IntelliJ IDEA ###
.idea
*.iws
*.iml
*.ipr

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

### VS Code ###
.vscode/

# Archivos y carpetas adicionales
*.log
logs/
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.local
.env.*

# Otros
/out/
coverage/

